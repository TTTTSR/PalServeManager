do_help() {
    echo "Palworld Server Manager - palserve"
    echo ""
    echo "用法: palserve <命令> [选项]"
    echo ""
    echo "命令:"
    echo "  start [-d]    启动管理面板 (-d 后台运行)"
    echo "  stop          停止管理面板"
    echo "  restart       重启管理面板"
    echo "  status        查看运行状态"
    echo "  log [N]       查看日志 (默认 50 行, 交互式自动 tail -f)"
    echo "  update          从 GitHub 下载最新版本"
    echo "  install         一键部署 (SteamCMD + 二进制 + 注册 PATH)"
    echo "  palworld-install 安装幻兽帕鲁服务端"
    echo "  steamcmd        单独安装/修复 SteamCMD"
    echo "  help            显示此帮助"
    echo ""
    echo "示例:"
    echo "  palserve start -d         后台启动管理面板"
    echo "  palserve palworld-install 安装幻兽帕鲁服务端"
    echo "  palserve log 100          查看最近 100 行日志"
}

# === 主入口 ===
case "${1:-}" in
    start)
        shift
        do_start "$@"
        ;;
    stop)
        do_stop
        ;;
    restart)
        do_restart
        ;;
    status)
        do_status
        ;;
    log)
        do_log "${2:-50}"
        ;;
    update)
        do_update
        ;;
    install)
        do_install
        ;;
    steamcmd)
        install_steamcmd
        ;;
    palworld-install)
        install_palworld "${2:-/opt/palworld}"
        ;;
    help|--help|-h)
        do_help
        ;;
    *)
        if [ ! -L "/usr/local/bin/palserve" ] && [ ! -f "$BINARY" ]; then
            echo -e "${YELLOW}首次运行，开始部署...${NC}"
            do_install
        else
            do_help
        fi
        ;;
esac
